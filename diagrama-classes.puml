@startuml
title FitPass Gym Management - Diagrama de Classes

class Aluno {
  id: int
  nome: string
  cpf: string
  telefone: string
  email: string
  endereco: string
  status: string
}

class Plano {
  id: int
  nome: string
  tipo: string
  valor: double
  duracaoMeses: int
  ativo: boolean
}

class Pagamento {
  id: int
  data: Date
  valor: double
  status: string
  metodo: string
}

class Acesso {
  id: int
  dataHora: DateTime
  autorizado: boolean
}

class Aula {
  id: int
  nome: string
  horario: DateTime
  capacidade: int
}

class Agendamento {
  id: int
  data: Date
  status: string
}

class Presenca {
  id: int
  presente: boolean
}

class Instrutor {
  id: int
  nome: string
  especialidade: string
}

class AvaliacaoFisica {
  id: int
  data: Date
  peso: double
  imc: double
  gordura: double
  observacoes: string
}

class Notificacao {
  id: int
  mensagem: string
  dataEnvio: Date
  tipo: string
}

class Relatorio {
  id: int
  tipo: string
  dataGeracao: Date
}

' RELACIONAMENTOS

Aluno "1" -- "1" Plano : possui >
Aluno "1" -- "*" Pagamento : realiza >
Aluno "1" -- "*" Acesso : registra >
Aluno "1" -- "*" Agendamento : faz >
Aluno "1" -- "*" AvaliacaoFisica : possui >
Aluno "1" -- "*" Notificacao : recebe >

Plano "1" -- "*" Aluno

Pagamento "*" -- "1" Aluno

Acesso "*" -- "1" Aluno

Agendamento "*" -- "1" Aula
Agendamento "*" -- "1" Aluno

Aula "1" -- "*" Agendamento
Aula "1" -- "*" Presenca
Aula "1" -- "1" Instrutor

Presenca "*" -- "1" Aluno
Presenca "*" -- "1" Aula

Instrutor "1" -- "*" Aula
Instrutor "1" -- "*" AvaliacaoFisica

AvaliacaoFisica "*" -- "1" Aluno

Notificacao "*" -- "1" Aluno

@enduml